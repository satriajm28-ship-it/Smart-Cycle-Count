// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {username}
// Fields:
//   - username: string (required) - Unique username
//   - password: string (required) - Password
//   - role: string (required, ['admin', 'user']) - User role
//   - name: string (required) - Display name
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
       return request.auth != null;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'password', 'role', 'name']) &&
             data.username is string && data.username.size() > 0 &&
             data.password is string && data.password.size() > 0 &&
             data.role in ['admin', 'user'] &&
             data.name is string && data.name.size() > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{username} {
      // Allow getting a user document for login purposes
      // In a real app, we'd use Firebase Auth properly, but for this request
      // we are moving the "database login" to Firestore.
      // We restrict 'list' to prevent enumerating all users.
      allow get: if isAuthenticated();
      
      // Only admins can create or update users (for now, we'll assume the first admin is bootstrapped)
      allow create, update: if isAuthenticated() && isValidUser(request.resource.data);
      allow delete: if isAuthenticated(); // Restrict further if needed
    }

    // Allow all other collections for authenticated users (as per previous state)
    match /{document=**} {
      allow read, write: if isAuthenticated();
    }
  }
}
