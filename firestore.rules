// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: {username}
// Fields:
//   - username: string (required) - Unique username
//   - password: string (required) - Password
//   - role: string (required, ['admin', 'user']) - User role
//   - name: string (required) - Display name
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
       return request.auth != null;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'password', 'role', 'name']) &&
             data.username is string && data.username.size() > 0 &&
             data.password is string && data.password.size() > 0 &&
             data.role in ['admin', 'user'] &&
             data.name is string && data.name.size() > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Allow public access to all collections to support the custom login system
    // and ensure the app is functional even if Anonymous Auth is not yet enabled.
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
